                                  `((id . "server-1")
                                    (nonce . ,(plist-get args :nonce))
                                    (channel_id . "chat")))))
                      ((symbol-function 'disco-room--channel-buffer-p)
                       (lambda (&rest _args) t))
                      ((symbol-function 'message)
                       (lambda (&rest _args) nil)))
              (disco-room-send-message))
