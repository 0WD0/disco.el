;;; disco-notifications-test.el --- Tests for desktop notifications -*- lexical-binding: t; -*-

(require 'ert)
(require 'disco-notifications)

(defmacro disco-notifications-test--with-app (&rest body)
  "Evaluate BODY with one isolated live Disco Appkit session."
  (declare (indent 0) (debug t))
  `(let* ((app (appkit-start-app 'disco :id (make-symbol "notification-test")))
          (disco-runtime--app app))
     (unwind-protect
         (progn ,@body)
       (when (appkit-app-live-p app)
         (appkit-stop-app app)))))

(defun disco-notifications-test--message (&optional mention)
  "Return incoming test message, with direct MENTION when non-nil."
  `((id . "100") (channel_id . "c") (content . "hello")
    (author (id . "other") (username . "Alice"))
    (mentions . ,(if mention '(((id . "me"))) nil))
    (mention_everyone . nil) (mention_roles . nil)))

(ert-deftest disco-notifications-policy-honors-level-mute-and-ping ()
  (let ((channel '((id . "c") (type . 0)))
        (level 0)
        muted)
    (cl-letf (((symbol-function 'disco-state-channel)
               (lambda (_id) channel))
              ((symbol-function 'disco-gateway-current-user-id)
               (lambda () "me"))
              ((symbol-function 'disco-state-channel-muted-p)
               (lambda (_channel) muted))
              ((symbol-function 'disco-state-channel-notification-level)
               (lambda (_channel) level))
              ((symbol-function 'disco-notifications--room-visible-p)
               (lambda (_id) nil)))
      (should (disco-notifications-message-notify-p
               (disco-notifications-test--message)))
      (setq level 1)
      (should-not (disco-notifications-message-notify-p
                   (disco-notifications-test--message)))
      (setq muted t)
      (should (disco-notifications-message-notify-p
               (disco-notifications-test--message t))))))

(ert-deftest disco-notifications-policy-suppresses-self-and-visible-room ()
  (let ((message (disco-notifications-test--message)))
    (cl-letf (((symbol-function 'disco-state-channel)
               (lambda (_id) '((id . "c") (type . 1))))
              ((symbol-function 'disco-state-channel-muted-p) (lambda (_) nil))
              ((symbol-function 'disco-state-channel-notification-level) (lambda (_) 0))
              ((symbol-function 'disco-gateway-current-user-id) (lambda () "other"))
              ((symbol-function 'disco-notifications--room-visible-p) (lambda (_) nil)))
      (should-not (disco-notifications-message-notify-p message)))
    (cl-letf (((symbol-function 'disco-state-channel)
               (lambda (_id) '((id . "c") (type . 1))))
              ((symbol-function 'disco-state-channel-muted-p) (lambda (_) nil))
              ((symbol-function 'disco-state-channel-notification-level) (lambda (_) 0))
              ((symbol-function 'disco-gateway-current-user-id) (lambda () "me"))
              ((symbol-function 'disco-notifications--room-visible-p) (lambda (_) t)))
      (should-not (disco-notifications-message-notify-p message)))))

(ert-deftest disco-notifications-event-hook-dedupes-live-creates ()
  (let ((disco-notifications--seen (make-hash-table :test #'equal))
        (disco-notifications--seen-order nil)
        (disco-notifications--generation 0)
        (disco-notifications--delay-owners nil)
        (disco-notifications--timeout-owners nil)
        (disco-notifications--history nil)
        (disco-notifications--history-buffer nil)
        (disco-notifications--last-id nil)
        (disco-notifications--last-display-op nil)
        (disco-notifications-mode t)
        (disco-notifications-delay 0.5)
        cancelled
        scheduled)
    (disco-notifications-test--with-app
      (cl-letf (((symbol-function 'run-with-timer)
                 (lambda (_delay _repeat function &rest arguments)
                   (let ((timer (intern (format "timer-%d"
                                                (1+ (length scheduled))))))
                     (push (list function arguments timer) scheduled)
                     timer)))
                ((symbol-function 'timerp)
                 (lambda (timer) (memq timer '(timer-1 timer-2))))
                ((symbol-function 'cancel-timer)
                 (lambda (timer) (push timer cancelled))))
        (let ((event (list :type 'message-create
                           :message (disco-notifications-test--message t))))
          (disco-notifications--handle-event event)
          (disco-notifications--handle-event event))
        (should (= 1 (length scheduled)))
        (disco-notifications--handle-event '(:type ready))
        (should (= 0 (hash-table-count disco-notifications--seen)))
        (disco-notifications-reset-session-state)
        (should (equal cancelled '(timer-1)))))))

(ert-deftest disco-notifications-reset-invalidates-old-same-id-delivery ()
  (let ((disco-notifications--seen (make-hash-table :test #'equal))
        (disco-notifications--seen-order nil)
        (disco-notifications--generation 7)
        (disco-notifications--delay-owners nil)
        (disco-notifications--timeout-owners nil)
        (disco-notifications--history nil)
        (disco-notifications--history-buffer nil)
        (disco-notifications--last-id nil)
        (disco-notifications--last-display-op nil)
        (disco-notifications-mode t)
        (disco-notifications-delay 0.5)
        scheduled
        shown)
    (disco-notifications-test--with-app
      (cl-letf (((symbol-function 'run-with-timer)
                 (lambda (_delay _repeat function &rest arguments)
                   (let ((timer (intern (format "timer-%d"
                                                (1+ (length scheduled))))))
                     (push (list function arguments timer) scheduled)
                     timer)))
                ((symbol-function 'timerp)
                 (lambda (timer) (memq timer '(timer-1 timer-2))))
                ((symbol-function 'cancel-timer) #'ignore)
                ((symbol-function 'disco-notifications--show)
                 (lambda (message &optional _app _generation)
                   (push (alist-get 'content message) shown))))
        (let ((old-message (disco-notifications-test--message t)))
          (setf (alist-get 'content old-message) "OLD_ACCOUNT_SECRET")
          (disco-notifications--handle-event
           (list :type 'message-create :message old-message)))
        (let ((old-callback (car scheduled)))
          (disco-notifications-reset-session-state)
          (let ((new-message (disco-notifications-test--message t)))
            ;; Reusing an opaque id in a new account generation must schedule
            ;; the new message without making the old callback authoritative.
            (setf (alist-get 'content new-message) "NEW_ACCOUNT_MESSAGE")
            (disco-notifications--handle-event
             (list :type 'message-create :message new-message)))
          (let ((new-callback (car scheduled)))
            (apply (car old-callback) (cadr old-callback))
            (apply (car new-callback) (cadr new-callback))))
        (should (equal shown '("NEW_ACCOUNT_MESSAGE")))
        (should-not
         (string-match-p
          "OLD_ACCOUNT_SECRET"
          (prin1-to-string
           (list disco-notifications--history
                 disco-notifications--delay-owners
                 disco-notifications--timeout-owners))))
        (disco-notifications-reset-session-state)))))

(ert-deftest disco-notifications-old-app-timer-is-inert-in-new-app ()
  (let* ((old-app (appkit-start-app 'disco :id (make-symbol "old-account")))
         (new-app nil)
         (disco-runtime--app old-app)
         (disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order nil)
         (disco-notifications--generation 5)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history nil)
         (disco-notifications--history-buffer nil)
         (disco-notifications--last-id nil)
         (disco-notifications--last-display-op nil)
         (disco-notifications-mode t)
         (disco-notifications-delay 0.5)
         callback
         owner
         cancelled
         shown)
    (unwind-protect
        (cl-letf (((symbol-function 'run-with-timer)
                   (lambda (_delay _repeat function &rest arguments)
                     (setq callback (cons function arguments))
                     'old-app-timer))
                  ((symbol-function 'timerp)
                   (lambda (timer) (eq timer 'old-app-timer)))
                  ((symbol-function 'cancel-timer)
                   (lambda (timer) (push timer cancelled)))
                  ((symbol-function 'disco-gateway-stop) #'ignore)
                  ((symbol-function 'disco-notifications--show)
                   (lambda (message &optional _app _generation)
                     (push message shown))))
          (let ((message (disco-notifications-test--message t)))
            (setf (alist-get 'content message) "OLD_ACCOUNT_SECRET")
            (setq owner
                  (disco-notifications--schedule-delayed message)))
          (appkit-stop-app old-app)
          (should-not disco-notifications--delay-owners)
          (should-not (plist-get owner :handle))
          (should-not (plist-get owner :timer))
          (should-not
           (string-match-p
            "OLD_ACCOUNT_SECRET"
            (prin1-to-string disco-notifications--delay-owners)))
          (setq new-app
                (appkit-start-app 'disco :id (make-symbol "new-account"))
                disco-runtime--app new-app)
          ;; Generation alone is intentionally unchanged: exact application
          ;; identity and liveness must still reject this queued callback.
          (apply (car callback) (cdr callback))
          (should-not shown)
          (should (equal cancelled '(old-app-timer)))
          (disco-notifications-reset-session-state))
      (when (appkit-app-live-p old-app)
        (appkit-stop-app old-app))
      (when (appkit-app-live-p new-app)
        (appkit-stop-app new-app)))))

(ert-deftest disco-notifications-reset-falls-back-after-handle-cancel-failure ()
  (let* ((app (appkit-start-app 'disco :id (make-symbol "cancel-fallback")))
         (disco-runtime--app app)
         (disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order nil)
         (disco-notifications--generation 0)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history nil)
         (disco-notifications--history-buffer nil)
         (disco-notifications--last-id nil)
         (disco-notifications--last-display-op nil)
         (disco-notifications-mode t)
         (disco-notifications-delay 0.5)
         attempts
         cancelled
         owner)
    (unwind-protect
        (cl-letf (((symbol-function 'run-with-timer)
                   (lambda (&rest _) 'fragile-timer))
                  ((symbol-function 'timerp)
                   (lambda (timer) (eq timer 'fragile-timer)))
                  ((symbol-function 'cancel-timer)
                   (lambda (timer)
                     (setq attempts (1+ (or attempts 0)))
                     (if (= attempts 1)
                         (error "first cancellation failed")
                       (push timer cancelled))))
                  ((symbol-function 'disco-gateway-stop) #'ignore))
          (setq owner
                (disco-notifications--schedule-delayed
                 (disco-notifications-test--message t)))
          ;; Appkit's first attempt retires the handle even though the timer
          ;; backend fails.  Reset must use the retained raw timer directly.
          (appkit-stop-app app)
          (should (= attempts 1))
          (should-not (plist-get owner :handle))
          (disco-notifications-reset-session-state)
          (should (= attempts 2))
          (should (equal cancelled '(fragile-timer)))
          (should-not (plist-get owner :handle))
          (should-not (plist-get owner :timer)))
      (when (appkit-app-live-p app)
        (appkit-stop-app app)))))

