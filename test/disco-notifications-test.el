(ert-deftest disco-notifications-account-switch-preserves-reused-current-id ()
  (let* ((old-app (appkit-start-app 'disco :id (make-symbol "old-display")))
         new-app
         (disco-runtime--app old-app)
         (disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order nil)
         (disco-notifications--generation 6)
         (disco-notifications--display-sequence 0)
         (disco-notifications--active-display-op nil)
         (disco-notifications--reset-in-progress nil)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history nil)
         (disco-notifications--history-buffer nil)
         (disco-notifications--last-id nil)
         (disco-notifications--last-display-op nil)
         (disco-notifications-mode t)
         (disco-notifications-timeout nil)
         (outer (disco-notifications-test--message))
         (inner (disco-notifications-test--message))
         (old-generation disco-notifications--generation)
         (notify-count 0)
         closed)
    (setf (alist-get 'content outer) "old account outer"
          (alist-get 'content inner) "new account inner")
    (unwind-protect
        (cl-letf (((symbol-function 'disco-notifications-message-notify-p)
                   (lambda (_) t))
                  ((symbol-function 'disco-notifications--title)
                   (lambda (&rest _) "title"))
                  ((symbol-function 'disco-notifications--body)
                   (lambda (_) "body"))
                  ((symbol-function 'disco-notifications--message-ping-p)
                   (lambda (_) nil))
                  ((symbol-function 'disco-gateway-stop) #'ignore)
                  ((symbol-function 'notifications-notify)
                   (lambda (&rest _)
                     (cl-incf notify-count)
                     (when (= notify-count 1)
                       (disco-notifications-reset-session-state)
                       (appkit-stop-app old-app)
                       (setq new-app
                             (appkit-start-app
                              'disco :id (make-symbol "new-display"))
                             disco-runtime--app new-app)
                       (disco-notifications--show
                        inner new-app disco-notifications--generation))
                     'same-account-switched-id))
                  ((symbol-function 'notifications-close-notification)
                   (lambda (id) (push id closed))))
          (disco-notifications--show outer old-app old-generation)
          (should (eq disco-runtime--app new-app))
          (should (eq disco-notifications--last-id
                      'same-account-switched-id))
          (should
           (equal disco-notifications--last-display-op
                  disco-notifications--active-display-op))
          (should (= 2 notify-count))
          (should-not closed)
          (should
           (equal (mapcar (lambda (message) (alist-get 'content message))
                          (ring-elements disco-notifications--history))
                  '("new account inner"))))
      (when (appkit-app-live-p old-app)
        (appkit-stop-app old-app))
      (when (appkit-app-live-p new-app)
        (appkit-stop-app new-app)))))

