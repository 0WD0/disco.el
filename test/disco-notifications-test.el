(ert-deftest disco-notifications-reset-barrier-rejects-reentrant-work ()
  (let* ((disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order nil)
         (disco-notifications--generation 8)
         (disco-notifications--display-sequence 0)
         (disco-notifications--active-display-op nil)
         (disco-notifications--reset-in-progress nil)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history nil)
         (history-buffer (generate-new-buffer " *notification-reset-reentry*"))
         (disco-notifications--history-buffer history-buffer)
         (disco-notifications--last-id nil)
         (disco-notifications--last-display-op nil)
         (disco-notifications-mode t)
         (disco-notifications-delay 0.5)
         (scheduled 0)
         cancelled)
    (disco-notifications-test--with-app
      (unwind-protect
          (progn
            (with-current-buffer history-buffer
              (setq-local disco-notifications--history-owner-p t)
              (add-hook
               'kill-buffer-hook
               (lambda ()
                 (disco-notifications--schedule-delayed
                  (disco-notifications-test--message t)))
               nil t))
            (cl-letf (((symbol-function 'run-with-timer)
                       (lambda (&rest _)
                         (cl-incf scheduled)
                         'reset-reentry-timer))
                      ((symbol-function 'timerp)
                       (lambda (timer) (eq timer 'reset-reentry-timer)))
                      ((symbol-function 'cancel-timer)
                       (lambda (timer)
                         (push timer cancelled)
                         (disco-notifications--handle-event
                          (list :type 'message-create
                                :message
                                (disco-notifications-test--message t))))))
              (disco-notifications--schedule-delayed
               (disco-notifications-test--message t))
              (disco-notifications-reset-session-state))
            (should (= scheduled 1))
            (should (equal cancelled '(reset-reentry-timer)))
            (should-not disco-notifications--delay-owners)
            (should-not disco-notifications--timeout-owners)
            (should-not disco-notifications--seen-order)
            (should (= 0 (hash-table-count disco-notifications--seen))))
        (when (buffer-live-p history-buffer)
          (kill-buffer history-buffer))))))

