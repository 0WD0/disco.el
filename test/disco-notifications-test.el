(ert-deftest disco-notifications-reset-drains-history-kill-successors ()
  (let* ((disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order nil)
         (disco-notifications--generation 1)
         (disco-notifications--display-sequence 0)
         (disco-notifications--active-display-op nil)
         (disco-notifications--reset-in-progress nil)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history nil)
         (history-buffer (generate-new-buffer " *history-drain-old*"))
         (disco-notifications--history-buffer history-buffer)
         (disco-notifications--last-id nil)
         (disco-notifications--last-display-op nil)
         successor)
    (unwind-protect
        (progn
          (with-current-buffer history-buffer
            (special-mode)
            (setq-local disco-notifications--history-owner-p t)
            (let ((inhibit-read-only t))
              (insert "OLD_ACCOUNT_SECRET old history"))
            (add-hook
             'kill-buffer-hook
             (lambda ()
               (unless successor
                 (setq successor
                       (generate-new-buffer " *history-drain-successor*")
                       disco-notifications--history-buffer successor)
                 (with-current-buffer successor
                   (special-mode)
                   (setq-local disco-notifications--history-owner-p t)
                   (let ((inhibit-read-only t))
                     (insert "OLD_ACCOUNT_SECRET copied successor")))))
             nil t))
          (disco-notifications-reset-session-state)
          (should-not (buffer-live-p history-buffer))
          (should-not (buffer-live-p successor))
          (should-not disco-notifications--history-buffer)
          (should-not
           (string-match-p
            "OLD_ACCOUNT_SECRET"
            (prin1-to-string
             (list disco-notifications--history
                   disco-notifications--history-buffer)))))
      (dolist (buffer (list history-buffer successor))
        (when (buffer-live-p buffer)
          (with-current-buffer buffer
            (let ((kill-buffer-hook nil))
              (kill-buffer buffer))))))))

