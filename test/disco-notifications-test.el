(ert-deftest disco-notifications-reset-clears-history-and-timeout-lifecycle ()
  (let* ((disco-notifications--seen (make-hash-table :test #'equal))
         (disco-notifications--seen-order '("100"))
         (disco-notifications--generation 11)
         (disco-notifications--delay-owners nil)
         (disco-notifications--timeout-owners nil)
         (disco-notifications--history (make-ring 4))
         (history-buffer
          (generate-new-buffer disco-notifications--history-buffer-name))
         (disco-notifications--history-buffer history-buffer)
         (disco-notifications--last-id 'old-notification)
         (disco-notifications--last-display-op 1)
         (disco-notifications--display-sequence 1)
         (disco-notifications--active-display-op 1)
         (disco-notifications-mode t)
         scheduled
         cancelled
         closed
         timeout-owner)
    (disco-notifications-test--with-app
      (unwind-protect
          (progn
            (ring-insert
             disco-notifications--history
             '((id . "100") (content . "OLD_ACCOUNT_SECRET")))
            (with-current-buffer history-buffer
              (special-mode)
              (rename-buffer
               (generate-new-buffer-name " *renamed-disco-history*"))
              (let ((inhibit-read-only t))
                (insert "OLD_ACCOUNT_SECRET")))
            (cl-letf (((symbol-function 'run-with-timer)
                       (lambda (_delay _repeat function &rest arguments)
                         (let ((timer
                                (intern
                                 (format "timer-%d"
                                         (1+ (length scheduled))))))
                           (push (list function arguments timer) scheduled)
                           timer)))
                      ((symbol-function 'timerp)
                       (lambda (timer) (memq timer '(timer-1 timer-2))))
                      ((symbol-function 'cancel-timer)
                       (lambda (timer) (push timer cancelled)))
                      ((symbol-function 'notifications-close-notification)
                       (lambda (id) (push id closed))))
              (disco-notifications--schedule-delayed
               (disco-notifications-test--message t))
              (setq timeout-owner
                    (disco-notifications--schedule-timeout
                     'old-notification
                     disco-runtime--app
                     disco-notifications--generation
                     disco-notifications--active-display-op))
              (disco-notifications-reset-session-state)
              ;; An already-queued old timeout cannot close a new session's
              ;; notification even if the desktop backend reuses identifiers.
              (setq disco-notifications--last-id 'new-notification
                    disco-notifications--last-display-op 'new-display)
              (disco-notifications--timeout-fired timeout-owner))
            (should-not (buffer-live-p history-buffer))
            (should-not disco-notifications--history)
            (should-not disco-notifications--delay-owners)
            (should-not disco-notifications--timeout-owners)
            (should-not disco-notifications--seen-order)
            (should (= 0 (hash-table-count disco-notifications--seen)))
            (should (eq disco-notifications--last-id 'new-notification))
            (should
             (equal (sort (mapcar #'symbol-name cancelled) #'string-lessp)
                    '("timer-1" "timer-2")))
            (should (equal closed '(old-notification))))
        (when (buffer-live-p history-buffer)
          (kill-buffer history-buffer))))))

