(ert-deftest disco-notifications-nested-show-keeps-newer-display-authoritative ()
  (let ((disco-notifications--seen (make-hash-table :test #'equal))
        (disco-notifications--seen-order nil)
        (disco-notifications--generation 3)
        (disco-notifications--display-sequence 0)
        (disco-notifications--active-display-op nil)
        (disco-notifications--reset-in-progress nil)
        (disco-notifications--delay-owners nil)
        (disco-notifications--timeout-owners nil)
        (disco-notifications--history nil)
        (disco-notifications--history-buffer nil)
        (disco-notifications--last-id nil)
        (disco-notifications--last-display-op nil)
        (disco-notifications-mode t)
        (disco-notifications-timeout nil)
        (outer (disco-notifications-test--message))
        (inner (disco-notifications-test--message))
        (notify-count 0)
        closed)
    (setf (alist-get 'id outer) "outer"
          (alist-get 'content outer) "outer message"
          (alist-get 'id inner) "inner"
          (alist-get 'content inner) "inner message")
    (disco-notifications-test--with-app
      (let ((generation disco-notifications--generation))
        (cl-letf (((symbol-function 'disco-notifications-message-notify-p)
                   (lambda (_) t))
                  ((symbol-function 'disco-notifications--title)
                   (lambda (&rest _) "title"))
                  ((symbol-function 'disco-notifications--body)
                   (lambda (_) "body"))
                  ((symbol-function 'disco-notifications--message-ping-p)
                   (lambda (_) nil))
                  ((symbol-function 'notifications-notify)
                   (lambda (&rest _)
                     (cl-incf notify-count)
                     (if (= notify-count 1)
                         (progn
                           (disco-notifications--show inner app generation)
                           'outer-id)
                       'inner-id)))
                  ((symbol-function 'notifications-close-notification)
                   (lambda (id) (push id closed))))
          (disco-notifications--show outer app generation)
          (should (eq disco-notifications--last-id 'inner-id))
          (should (= 2 notify-count))
          (should (equal closed '(outer-id)))
          (should
           (equal (mapcar (lambda (message) (alist-get 'content message))
                          (ring-elements disco-notifications--history))
                  '("inner message"))))))))

(ert-deftest disco-notifications-nested-policy-or-preparation-stales-outer ()
  (dolist (boundary '(policy preparation))
    (let ((disco-notifications--seen (make-hash-table :test #'equal))
          (disco-notifications--seen-order nil)
          (disco-notifications--generation 3)
          (disco-notifications--display-sequence 0)
          (disco-notifications--active-display-op nil)
          (disco-notifications--reset-in-progress nil)
          (disco-notifications--delay-owners nil)
          (disco-notifications--timeout-owners nil)
          (disco-notifications--history nil)
          (disco-notifications--history-buffer nil)
          (disco-notifications--last-id nil)
          (disco-notifications--last-display-op nil)
          (disco-notifications-mode t)
          (disco-notifications-timeout nil)
          (outer (disco-notifications-test--message))
          (inner (disco-notifications-test--message))
          nested-p
          (notify-count 0)
          closed)
      (setf (alist-get 'id outer) "outer-reservation"
            (alist-get 'content outer) "outer reservation"
            (alist-get 'id inner) "inner-reservation"
            (alist-get 'content inner) "inner reservation")
      (disco-notifications-test--with-app
        (let ((generation disco-notifications--generation))
          (cl-labels
              ((maybe-nest (message at-boundary)
                 (when (and (eq boundary at-boundary)
                            (equal (alist-get 'id message)
                                   "outer-reservation")
                            (not nested-p))
                   (setq nested-p t)
                   (disco-notifications--show inner app generation))))
            (cl-letf (((symbol-function 'disco-notifications-message-notify-p)
                       (lambda (message)
                         (maybe-nest message 'policy)
                         t))
                      ((symbol-function 'disco-notifications--title)
                       (lambda (message &rest _)
                         (maybe-nest message 'preparation)
                         (alist-get 'id message)))
                      ((symbol-function 'disco-notifications--body)
                       (lambda (_) "body"))
                      ((symbol-function 'disco-notifications--message-ping-p)
                       (lambda (_) nil))
                      ((symbol-function 'notifications-notify)
                       (lambda (&rest args)
                         (cl-incf notify-count)
                         (intern (concat (plist-get args :title) "-backend"))))
                      ((symbol-function 'notifications-close-notification)
                       (lambda (id) (push id closed))))
              (disco-notifications--show outer app generation)
              (ert-info ((format "synchronous boundary: %S" boundary))
                (should (eq disco-notifications--last-id
                            'inner-reservation-backend))
                (should (= notify-count 1))
                (should-not closed)
                (should
                 (equal
                  (mapcar (lambda (message) (alist-get 'content message))
                          (ring-elements disco-notifications--history))
                  '("inner reservation")))))))))))

